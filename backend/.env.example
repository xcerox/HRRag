# ── App ────────────────────────────────────────────────────
APP_PORT=80

# ── Backend ────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-un-secreto-de-minimo-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL + pgvector ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hrrag
POSTGRES_USER=hrrag
POSTGRES_PASSWORD=hrrag

# ── Embeddings ─────────────────────────────────────────────
EMBEDDING_DIM=768
N_RESULTS=6
MIN_SIMILARITY=0.45

# ── Ollama (corre nativo en el host) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=120

# ── Storage ────────────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE_MB=50
